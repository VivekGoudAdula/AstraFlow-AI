# Lyzr API Key (required for agent calls)
LYZR_API_KEY=your-lyzr-api-key-here

# Optional: Agent ID (can also be set per-component)
AGENT_ID=your-agent-id-here

# Google Sheets Configuration
# 1. Create a Google Sheet manually
# 2. Extract ID from URL: https://docs.google.com/spreadsheets/d/YOUR_ID_HERE/edit
# 3. Share the sheet with your service account email (Editor access)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "...", ...}'
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
QDRANT_API_KEY= YOUR_QDRANT_API_KEY
#Apify API Key (Required for high-integrity LinkedIn profile discovery)
NEXT_PUBLIC_APIFY_API_KEY=your_apify_token_here
APIFY_API_KEY=your_apify_key_here